generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  BLAZIE
}

enum CampaignRole {
  OWNER
  MANAGER
  MEMBER
}

enum Platform {
  TIKTOK
  INSTAGRAM_REELS
  YOUTUBE_SHORTS
}

enum CreatorStatus {
  NEW
  QUALIFIED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OutreachStatus {
  NOT_STARTED
  CONTACTED
  RESPONDED
  NO_RESPONSE
}

enum DealStatus {
  LEAD
  NEGOTIATING
  AGREED
  DECLINED
  CLOSED
}

enum DeliverableStatus {
  NOT_BRIEFED
  CONTENT_DUE
  CONTENT_RECEIVED
  APPROVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

enum PostingStatus {
  NOT_SCHEDULED
  READY_TO_POST
  POSTED
  ARCHIVED
}

enum PayoutStatus {
  PENDING
  APPROVED
  SCHEDULED
  PAID
  FAILED
  CANCELLED
}

enum CreatorDealPaidTrafficMetric {
  VIDEO_PLAY_ACTIONS
  IMPRESSIONS
}

enum CreatorDealPerVideoCapScope {
  CPM
  TOTAL
  NONE
}

enum NoteEntityType {
  ORGANIZATION
  CAMPAIGN
  CREATOR
  VIDEO
  CAMPAIGN_CREATOR
  PAYOUT
}

enum ActivityEntityType {
  ORGANIZATION
  CAMPAIGN
  CREATOR
  VIDEO
  CAMPAIGN_CREATOR
  PAYOUT
  SYNC_JOB
}

enum SyncJobType {
  ORGANIZATION_IMPORT
  CREATOR_IMPORT
  CREATOR_REFRESH
  VIDEO_REFRESH
  CAMPAIGN_REFRESH
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum ViralPostEnrichmentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  RATE_LIMITED
}

enum ExternalSource {
  DATA_PROVIDER
}

enum SourceEntityType {
  CREATOR
  PLATFORM_ACCOUNT
  VIDEO
  CAMPAIGN
}

enum MessagingChannel {
  SMS
  WHATSAPP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageParseStatus {
  NOT_ATTEMPTED
  NO_CODE_FOUND
  CODE_FOUND
  APPLIED
  FAILED
}

enum MessageThreadState {
  IDLE
  AWAITING_SPARK_CODE
  CODE_RECEIVED
  AUTH_APPLIED
  FAILED
}

enum SparkCodeRequestStatus {
  PENDING
  RECEIVED
  AUTHORIZED
  FAILED
  EXPIRED
  CANCELLED
}

enum SparkAuthorizationStatus {
  PENDING
  AUTHORIZED
  FAILED
  EXPIRED
  REVOKED
}

enum ReportingDayBuildStatus {
  RUNNING
  SUCCEEDED
  INCOMPLETE
  FAILED
  SUPERSEDED
}

enum ReportingFreshness {
  FRESH
  STALE
  INCOMPLETE
  SUPERSEDED
}

model User {
  id                          String                   @id @default(cuid())
  name                        String?
  email                       String?                  @unique
  emailVerified               DateTime?
  image                       String?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  accounts                    Account[]
  sessions                    Session[]
  memberships                 OrganizationMembership[]
  campaignMemberships         CampaignMembership[]
  ownedCampaigns              Campaign[]               @relation("CampaignOwner")
  organizationInvitationsSent OrganizationInvitation[] @relation("OrganizationInvitationInvitedBy")
  campaignInvitationsSent     CampaignInvitation[]     @relation("CampaignInvitationInvitedBy")
  notesAuthored               Note[]
  activities                  Activity[]
  syncJobs                    ExternalSyncJob[]
  videoReviews                VideoReview[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Organization {
  id                        String                      @id @default(cuid())
  name                      String
  slug                      String                      @unique
  createdById               String?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  memberships               OrganizationMembership[]
  invitations               OrganizationInvitation[]
  campaigns                 Campaign[]
  creators                  Creator[]
  tags                      Tag[]
  payouts                   Payout[]
  notes                     Note[]
  activities                Activity[]
  syncJobs                  ExternalSyncJob[]
  sourceMaps                SourceMapping[]
  viralPostEnrichments      ViralPostEnrichment[]
  twilioConfig              OrganizationTwilioConfig?
  tiktokAccounts            OrganizationTikTokAccount[]
  integrationCredentials    OrganizationIntegrationCredential[]
  messageThreads            CreatorMessageThread[]
  sparkCodeRequests         SparkCodeRequest[]
  messageEvents             CreatorMessageEvent[]
  sparkAuthorizations       SparkAuthorization[]
  creatorDeals              CampaignCreatorDeal[]
  creatorVideoDeals         CampaignCreatorVideoDeal[]
  videoContentClassifications VideoContentClassification[]
  tiktokPaidMetricSnapshots TikTokPaidMetricSnapshot[]
  tiktokAdPreviewUrls       TikTokAdPreviewUrl[]
  reportingDayVersions      ReportingDayVersion[]
  reportingDailyFacts       ReportingDailyFact[]
  creatorPortalAccesses     CreatorPortalAccess[]
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationInvitation {
  id              String           @id @default(cuid())
  organizationId  String
  email           String
  role            OrganizationRole @default(MEMBER)
  invitedByUserId String?
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User?            @relation("OrganizationInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([email, acceptedAt, revokedAt])
  @@index([organizationId, acceptedAt, revokedAt])
}

model Campaign {
  id             String               @id @default(cuid())
  organizationId String
  ownerUserId    String?
  name           String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User?                @relation("CampaignOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  memberships    CampaignMembership[]
  invitations    CampaignInvitation[]
  creators       CampaignCreator[]
  videos         Video[]
  payouts        Payout[]

  @@index([organizationId, createdAt])
}

model CampaignMembership {
  id         String       @id @default(cuid())
  campaignId String
  userId     String
  role       CampaignRole @default(MEMBER)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
}

model CampaignInvitation {
  id              String       @id @default(cuid())
  campaignId      String
  email           String
  role            CampaignRole @default(MEMBER)
  invitedByUserId String?
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  campaign        Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invitedBy       User?        @relation("CampaignInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([campaignId, email])
  @@index([email, acceptedAt, revokedAt])
  @@index([campaignId, acceptedAt, revokedAt])
}

model Creator {
  id                        String                     @id @default(cuid())
  organizationId            String
  displayName               String
  primaryNiche              String?
  region                    String?
  language                  String?
  internalStatus            CreatorStatus              @default(NEW)
  notesSummary              String?
  contactEmail              String?
  customTags                String[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platformAccounts          CreatorPlatformAccount[]
  metricsSnapshots          CreatorMetricsSnapshot[]
  campaignLinks             CampaignCreator[]
  videos                    Video[]
  creatorTags               CreatorTag[]
  payouts                   Payout[]
  contactPoints             CreatorContactPoint[]
  messageThreads            CreatorMessageThread[]
  sparkCodeRequests         SparkCodeRequest[]
  messageEvents             CreatorMessageEvent[]
  sparkAuthorizations       SparkAuthorization[]
  tiktokPaidMetricSnapshots TikTokPaidMetricSnapshot[]
  portalAccesses            CreatorPortalAccess[]

  @@index([organizationId, internalStatus])
}

model CreatorPlatformAccount {
  id                    String                   @id @default(cuid())
  creatorId             String
  platform              Platform
  sourceAccountId       String?
  handle                String
  profileUrl            String?
  followerCount         Int?
  averageViews          Int?
  averageEngagementRate Float?
  contactInfo           Json?
  lastSyncedAt          DateTime?
  rawPayload            Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  creator               Creator                  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  metricsSnapshots      CreatorMetricsSnapshot[]
  videos                Video[]

  @@unique([platform, sourceAccountId])
  @@unique([creatorId, platform, handle])
  @@index([creatorId, platform])
}

model CreatorMetricsSnapshot {
  id                    String                  @id @default(cuid())
  creatorId             String
  platformAccountId     String?
  capturedAt            DateTime                @default(now())
  followerCount         Int?
  averageViews          Int?
  averageEngagementRate Float?
  sourcePayload         Json?
  creator               Creator                 @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  platformAccount       CreatorPlatformAccount? @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)

  @@index([creatorId, capturedAt])
}

model CampaignCreator {
  id                String            @id @default(cuid())
  campaignId        String
  creatorId         String
  outreachStatus    OutreachStatus    @default(NOT_STARTED)
  dealStatus        DealStatus        @default(LEAD)
  deliverableStatus DeliverableStatus @default(NOT_BRIEFED)
  approvalStatus    ApprovalStatus    @default(PENDING)
  postingStatus     PostingStatus     @default(NOT_SCHEDULED)
  payoutStatus      PayoutStatus      @default(PENDING)
  agreedRate        Decimal?          @db.Decimal(12, 2)
  dueDate           DateTime?
  deliveredAt       DateTime?
  postedAt          DateTime?
  internalNotes     String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  campaign          Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator           Creator           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  deals             CampaignCreatorDeal[]
  videoDeals        CampaignCreatorVideoDeal[]
  payouts           Payout[]
  portalAccesses    CreatorPortalAccess[]

  @@unique([campaignId, creatorId])
  @@index([campaignId, dealStatus])
  @@index([creatorId, payoutStatus])
}

model CreatorPortalAccess {
  id                String           @id @default(cuid())
  organizationId    String
  creatorId         String
  campaignCreatorId String?
  linkTokenHash     String           @unique
  encryptedLinkToken String?
  codeHash          String           @unique
  codePrefix        String
  revokedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator           Creator          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  campaignCreator   CampaignCreator? @relation(fields: [campaignCreatorId], references: [id], onDelete: SetNull)

  @@index([organizationId, creatorId])
  @@index([campaignCreatorId])
  @@index([revokedAt])
}

model CampaignCreatorDeal {
  id                      String                       @id @default(cuid())
  organizationId          String
  campaignCreatorId       String
  currency                String                       @default("USD")
  effectiveStartDate      DateTime
  effectiveEndDate        DateTime?
  fixedFee                Decimal?                     @db.Decimal(12, 2)
  fixedFeeRecognitionDate DateTime?
  fixedFeePerVideo        Decimal?                     @db.Decimal(12, 2)
  cpmAmount               Decimal?                     @default(1) @db.Decimal(12, 2)
  paidTrafficMetric       CreatorDealPaidTrafficMetric @default(IMPRESSIONS)
  deductPaidTraffic       Boolean                      @default(true)
  viewCapPerVideo         Int?
  viewWindowDays          Int?                         @default(7)
  payoutCapPerVideo       Decimal?                     @default(100) @db.Decimal(12, 2)
  perVideoCapScope        CreatorDealPerVideoCapScope  @default(CPM)
  payoutCapTotal          Decimal?                     @db.Decimal(12, 2)
  notes                   String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  organization            Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignCreator         CampaignCreator              @relation(fields: [campaignCreatorId], references: [id], onDelete: Cascade)

  @@index([campaignCreatorId])
  @@index([organizationId, effectiveStartDate])
  @@index([organizationId, effectiveEndDate])
}

model CampaignCreatorVideoDeal {
  id                String                       @id @default(cuid())
  organizationId    String
  campaignCreatorId String
  sourceVideoId     String
  fixedFeePerVideo  Decimal?                     @db.Decimal(12, 2)
  cpmAmount         Decimal?                     @default(1) @db.Decimal(12, 2)
  paidTrafficMetric CreatorDealPaidTrafficMetric @default(IMPRESSIONS)
  deductPaidTraffic Boolean                      @default(true)
  viewCapPerVideo   Int?
  payoutCapPerVideo Decimal?                     @default(100) @db.Decimal(12, 2)
  perVideoCapScope  CreatorDealPerVideoCapScope  @default(CPM)
  notes             String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignCreator   CampaignCreator              @relation(fields: [campaignCreatorId], references: [id], onDelete: Cascade)

  @@unique([campaignCreatorId, sourceVideoId])
  @@index([organizationId, sourceVideoId])
  @@index([campaignCreatorId])
}

model Video {
  id                        String                     @id @default(cuid())
  creatorId                 String
  creatorPlatformAccountId  String?
  campaignId                String?
  sourceVideoId             String?
  platform                  Platform
  videoUrl                  String
  titleOrCaption            String?
  publishedAt               DateTime?
  views                     Int?
  likes                     Int?
  comments                  Int?
  engagementRate            Float?
  contentTags               String[]
  hookSummary               String?
  isTalking                 Boolean                    @default(true)
  rawPayload                Json?
  lastSyncedAt              DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  creator                   Creator                    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorPlatformAccount    CreatorPlatformAccount?    @relation(fields: [creatorPlatformAccountId], references: [id], onDelete: SetNull)
  campaign                  Campaign?                  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  metricsSnapshots          VideoMetricsSnapshot[]
  reviews                   VideoReview[]
  sparkCodeRequests         SparkCodeRequest[]
  sparkAuthorizations       SparkAuthorization[]
  tiktokPaidMetricSnapshots TikTokPaidMetricSnapshot[]

  @@unique([platform, sourceVideoId])
  @@index([creatorId, publishedAt])
  @@index([campaignId, platform])
}

model VideoContentClassification {
  id             String       @id @default(cuid())
  organizationId String
  platform       Platform     @default(TIKTOK)
  sourceVideoId  String
  isTalking      Boolean      @default(true)
  formatTag      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform, sourceVideoId])
  @@index([organizationId, isTalking])
  @@index([organizationId, formatTag])
}

model VideoReview {
  id             String   @id @default(cuid())
  videoId        String
  reviewerUserId String
  reviewedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  reviewer       User     @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@unique([videoId, reviewerUserId])
  @@index([reviewerUserId, reviewedAt])
}

model VideoMetricsSnapshot {
  id             String   @id @default(cuid())
  videoId        String
  capturedAt     DateTime @default(now())
  views          Int?
  likes          Int?
  comments       Int?
  engagementRate Float?
  sourcePayload  Json?
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId, capturedAt])
}

model OrganizationTwilioConfig {
  id                  String       @id @default(cuid())
  organizationId      String       @unique
  messagingServiceSid String?
  smsFrom             String?
  whatsappFrom        String?
  enabled             Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationTikTokAccount {
  id                    String       @id @default(cuid())
  organizationId        String
  advertiserId          String
  advertiserName        String?
  accessToken           String
  refreshToken          String?
  tokenType             String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 Json?
  status                String       @default("ACTIVE")
  lastValidatedAt       DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, advertiserId])
  @@index([organizationId, status])
}

model OrganizationIntegrationCredential {
  id                   String       @id @default(cuid())
  organizationId       String
  key                  String
  encryptedValue       String
  valuePreview         String?
  lastValidatedAt      DateTime?
  lastValidationStatus String?
  lastValidationError  String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model ReportingDayVersion {
  id                   String                  @id @default(cuid())
  organizationId       String
  reportDate           DateTime
  version              Int
  status               ReportingDayBuildStatus @default(RUNNING)
  freshness            ReportingFreshness      @default(INCOMPLETE)
  isCurrent            Boolean                 @default(false)
  pricingConfigVersion String?
  sourceConfigVersion  String?
  sourceState          Json?
  warnings             Json?
  error                Json?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  completedAt          DateTime?
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facts                ReportingDailyFact[]

  @@unique([organizationId, reportDate, version])
  @@index([organizationId, reportDate, isCurrent])
  @@index([organizationId, freshness, reportDate])
  @@index([organizationId, status, createdAt])
}

model ReportingDailyFact {
  id             String              @id @default(cuid())
  dayVersionId   String
  organizationId String
  reportDate     DateTime
  metricKey      String
  value          Decimal             @db.Decimal(18, 6)
  unit           String?
  currency       String?
  source         String              @default("total")
  bucket         String              @default("total")
  dimensionsKey  String              @default("default")
  dimensions     Json?
  provenance     Json?
  createdAt      DateTime            @default(now())
  dayVersion     ReportingDayVersion @relation(fields: [dayVersionId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([dayVersionId, metricKey, source, bucket, dimensionsKey])
  @@index([dayVersionId])
  @@index([organizationId, reportDate, metricKey])
  @@index([organizationId, reportDate, source, bucket])
  @@index([organizationId, reportDate, metricKey, source, bucket])
}

model CreatorContactPoint {
  id            String                 @id @default(cuid())
  creatorId     String
  channel       MessagingChannel
  phoneE164     String
  isPrimary     Boolean                @default(false)
  verifiedAt    DateTime?
  optInAt       DateTime?
  optOutAt      DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  creator       Creator                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  threads       CreatorMessageThread[]
  requests      SparkCodeRequest[]
  messageEvents CreatorMessageEvent[]

  @@unique([channel, phoneE164])
  @@index([creatorId, channel, isPrimary])
}

model SparkCodeRequest {
  id             String                 @id @default(cuid())
  organizationId String
  creatorId      String
  videoId        String?
  contactPointId String?
  threadId       String?
  channel        MessagingChannel
  requestToken   String                 @unique
  status         SparkCodeRequestStatus @default(PENDING)
  requestedAt    DateTime               @default(now())
  expiresAt      DateTime?
  receivedAt     DateTime?
  authorizedAt   DateTime?
  failedAt       DateTime?
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        Creator                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  video          Video?                 @relation(fields: [videoId], references: [id], onDelete: SetNull)
  contactPoint   CreatorContactPoint?   @relation(fields: [contactPointId], references: [id], onDelete: SetNull)
  thread         CreatorMessageThread?  @relation(fields: [threadId], references: [id], onDelete: SetNull)
  messageEvents  CreatorMessageEvent[]
  authorizations SparkAuthorization[]

  @@index([organizationId, creatorId, status, requestedAt])
  @@index([creatorId, channel, status, requestedAt])
  @@index([threadId, requestedAt])
}

model CreatorMessageThread {
  id             String                @id @default(cuid())
  organizationId String
  creatorId      String
  contactPointId String?
  channel        MessagingChannel
  state          MessageThreadState    @default(IDLE)
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        Creator               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  contactPoint   CreatorContactPoint?  @relation(fields: [contactPointId], references: [id], onDelete: SetNull)
  requests       SparkCodeRequest[]
  messageEvents  CreatorMessageEvent[]

  @@unique([creatorId, channel])
  @@index([organizationId, state, updatedAt])
}

model CreatorMessageEvent {
  id                 String                @id @default(cuid())
  organizationId     String
  creatorId          String?
  sparkCodeRequestId String?
  threadId           String?
  contactPointId     String?
  direction          MessageDirection
  providerMessageSid String                @unique
  channel            MessagingChannel
  fromE164           String
  toE164             String
  body               String
  parseStatus        MessageParseStatus    @default(NOT_ATTEMPTED)
  parsedCodeHash     String?
  deliveryStatus     String?
  rawPayload         Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator            Creator?              @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  sparkCodeRequest   SparkCodeRequest?     @relation(fields: [sparkCodeRequestId], references: [id], onDelete: SetNull)
  thread             CreatorMessageThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  contactPoint       CreatorContactPoint?  @relation(fields: [contactPointId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([creatorId, createdAt])
  @@index([sparkCodeRequestId, createdAt])
  @@index([threadId, createdAt])
}

model SparkAuthorization {
  id                     String                   @id @default(cuid())
  organizationId         String
  creatorId              String
  videoId                String?
  sparkCodeRequestId     String?
  advertiserId           String
  authCodeHash           String
  identityType           String?
  identityId             String?
  identityAuthorizedBcId String?
  tiktokItemId           String?
  authStartTime          DateTime?
  authEndTime            DateTime?
  status                 SparkAuthorizationStatus @default(PENDING)
  lastError              String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator                Creator                  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  video                  Video?                   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  sparkCodeRequest       SparkCodeRequest?        @relation(fields: [sparkCodeRequestId], references: [id], onDelete: SetNull)

  @@unique([organizationId, advertiserId, authCodeHash])
  @@index([organizationId, status, updatedAt])
  @@index([creatorId, videoId, status])
}

model TikTokPaidMetricSnapshot {
  id               String       @id @default(cuid())
  organizationId   String
  creatorId        String
  videoId          String?
  advertiserId     String
  tiktokItemId     String?
  statDate         DateTime?
  reportStartDate  DateTime
  reportEndDate    DateTime
  impressions      Int?
  videoPlayActions Int?
  rawPayload       Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator          Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  video            Video?       @relation(fields: [videoId], references: [id], onDelete: SetNull)

  @@index([organizationId, creatorId, statDate])
  @@index([organizationId, advertiserId, tiktokItemId])
  @@index([videoId, statDate])
}

model TikTokAdPreviewUrl {
  id             String       @id @default(cuid())
  organizationId String
  advertiserId   String
  adId           String
  adName         String?
  previewUrl     String
  expiresAt      DateTime?
  importedAt     DateTime     @default(now())
  sourceFileName String?
  rawPayload     Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, advertiserId, adId])
  @@index([organizationId, advertiserId, expiresAt])
}

model Note {
  id             String         @id @default(cuid())
  organizationId String
  authorUserId   String?
  entityType     NoteEntityType
  entityId       String
  body           String
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User?          @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, entityType, entityId])
}

model Tag {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  color          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creatorTags    CreatorTag[]

  @@unique([organizationId, name])
}

model CreatorTag {
  id        String   @id @default(cuid())
  creatorId String
  tagId     String
  createdAt DateTime @default(now())
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([creatorId, tagId])
}

model Payout {
  id                String           @id @default(cuid())
  organizationId    String
  campaignId        String?
  creatorId         String?
  campaignCreatorId String?
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("USD")
  status            PayoutStatus     @default(PENDING)
  payoutDate        DateTime?
  paymentMethod     String?
  externalReference String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign          Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  creator           Creator?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  campaignCreator   CampaignCreator? @relation(fields: [campaignCreatorId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([campaignId, payoutDate])
}

model Activity {
  id             String             @id @default(cuid())
  organizationId String
  actorUserId    String?
  entityType     ActivityEntityType
  entityId       String
  action         String
  summary        String?
  metadata       Json?
  createdAt      DateTime           @default(now())
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?              @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

model ExternalSyncJob {
  id                String        @id @default(cuid())
  organizationId    String
  initiatedByUserId String?
  jobType           SyncJobType
  status            SyncJobStatus @default(QUEUED)
  resourceType      String
  resourceId        String?
  startedAt         DateTime?
  finishedAt        DateTime?
  errorMessage      String?
  requestPayload    Json?
  resultPayload     Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  initiatedBy       User?         @relation(fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([jobType, createdAt])
}

model SourceMapping {
  id                   String           @id @default(cuid())
  organizationId       String
  localEntityType      SourceEntityType
  localEntityId        String
  externalSource       ExternalSource   @default(DATA_PROVIDER)
  externalResourceType String
  externalId           String
  lastSyncedAt         DateTime?
  rawPayload           Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalSource, externalResourceType, externalId])
  @@unique([organizationId, localEntityType, localEntityId, externalSource])
}

model ViralPostEnrichment {
  id                  String                    @id @default(cuid())
  organizationId      String
  platform            String                    @default("tiktok")
  platformVideoId     String
  status              ViralPostEnrichmentStatus @default(PENDING)
  attemptCount        Int                       @default(0)
  nextAttemptAt       DateTime                  @default(now())
  processingStartedAt DateTime?
  lastFetchedAt       DateTime?
  lastError           String?
  accountDisplayName  String?
  accountUsername     String?
  caption             String?
  thumbnailUrl        String?
  videoUrl            String?
  publishedAt         DateTime?
  viewCount           Int?
  rawPayload          Json?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform, platformVideoId])
  @@index([organizationId, status, nextAttemptAt])
  @@index([platform, platformVideoId])
}
