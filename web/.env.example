SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_PK=""
SUPABASE_ANON_KEY=""
# Server-side fallback for auth plus the data client.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_SK=""
AUTH_SECRET="replace-with-a-long-random-string"
# Used for secure cookie behavior and email confirmation redirects.
AUTH_URL="http://localhost:3000"
DISABLE_AUTH="false"
# Legacy Google-only flag; Supabase Auth public access is controlled by DISABLE_AUTH.
DISABLE_GOOGLE_AUTH="false"

DATA_PROVIDER_BASE_URL="https://api.example.com"
DATA_PROVIDER_API_KEY=""
VIRAL_APP_BASE_URL="https://viral.app/api/v1/"
