VIEWSBASE_BASE_URL="https://www.viewsbase.com"
VIEWSBASE_SESSION_COOKIE_NAME="sb-euxaarvxbpiaipzmlesu-auth-token"
VIEWSBASE_SESSION_COOKIE_VALUE=""
VIEWSBASE_DEFAULT_ORG_SLUG=""

CRON_SECRET="replace-with-a-second-random-string"
NEXT_PUBLIC_APP_NAME="Billion Views"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_BASE_URL=""

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Optional when TWILIO_SMS_FROM / TWILIO_WHATSAPP_FROM is set
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_SMS_FROM=""
# Alias supported for SMS sender fallback
