TIKTOK_BUSINESS_BASE_URL="https://business-api.tiktok.com"
TIKTOK_AUTH_URL="https://business-api.tiktok.com/portal/auth"
TIKTOK_APP_ID=""
TIKTOK_SECRET=""
# Use the exact callback URL you register in TikTok For Business.
TIKTOK_REDIRECT="http://localhost:3000/api/integrations/tiktok/callback"

SINGULAR_API_BASE_URL="https://api.singular.net"
SINGULAR_API_KEY=""
# Optional: narrow reports to one or more Singular app names.
SINGULAR_APP_NAMES=""
# Optional override. Leave blank to auto-detect TikTok-like sources from Singular.
SINGULAR_SOURCE_NAMES=""
# Revenue window used for ROAS, for example 7d, 30d, actual, or ltv.
SINGULAR_COHORT_PERIOD="7d"

ADAPTY_API_BASE_URL="https://api-admin.adapty.io"
ADAPTY_API_KEY=""
ADAPTY_DASHBOARD_BASE_URL="https://api-asa-admin.adapty.io/api/v1"
ADAPTY_DASHBOARD_TOKEN=""
ADAPTY_DASHBOARD_COMPANY_ID=""
ADAPTY_DASHBOARD_APP_ID=""
# Comma-separated text matches for TikTok attribution labels returned by Adapty.
ADAPTY_TIKTOK_SOURCE_PATTERNS="tiktok,tik tok"
# Comma-separated Singular/Adapty source labels that are creator/UGC programs, not paid media.
ADAPTY_CREATOR_SOURCE_PATTERNS="social custom"
# Defaults to the plan's source segmentation. Use attribution_channel or attribution_campaign if your MMP maps TikTok there.
ADAPTY_TIKTOK_SEGMENTATION="attribution_source"

# Optional: stable encryption key for database-stored integration credentials.
# Defaults to AUTH_SECRET when blank.
INTEGRATION_CREDENTIALS_KEY=""

# IANA timezone used for UGC Pay report-date boundaries and post-date filtering.
UGC_PAY_REPORT_TIME_ZONE="UTC"
